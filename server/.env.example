# ===== Центр содействия кандидатам — конфигурация =====
# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env

# Порт, на котором работает Node-сервер (за ним стоит nginx)
PORT=3000

# --- Основной канал: n8n webhook (рекомендуется) ---
# В n8n создайте Webhook-ноду (Production URL) и вставьте сюда.
# n8n принимает JSON заявки и создаёт лид в Bitrix24 через ваш коннектор.
N8N_WEBHOOK_URL=https://your-n8n-host/webhook/csk-lead

# --- Опционально: прямая отправка в Bitrix24 (входящий вебхук) ---
# Если хотите слать лид в Bitrix24 напрямую, минуя n8n.
# Создайте в Bitrix24: Разработчикам → Входящий вебхук → права crm.
# Формат: https://ВАШ-ПОРТАЛ.bitrix24.ru/rest/ID_ПОЛЬЗОВАТЕЛЯ/КОД/
# Оставьте пустым, если используете только n8n.
BITRIX_WEBHOOK_URL=
BITRIX_SOURCE_ID=WEB

# Заголовок лида в CRM
LEAD_TITLE=Заявка с сайта (служба по контракту)
